{
  "config": { "wide_screen_mode": true },
  "header": {
    "title": { "tag": "plain_text", "content": "👤 {画像标题}" },
    "template": "turquoise"
  },
  "elements": [
    {
      "tag": "column_set",
      "flex_mode": "none",
      "background_style": "default",
      "columns": [
        {
          "tag": "column",
          "width": "weighted",
          "weight": 2,
          "vertical_align": "top",
          "elements": [
            {
              "tag": "div",
              "text": { "tag": "lark_md", "content": "**{name}**\n{title}\n{department}" }
            }
          ]
        },
        {
          "tag": "column",
          "width": "weighted",
          "weight": 1,
          "vertical_align": "top",
          "elements": [
            {
              "tag": "div",
              "text": { "tag": "lark_md", "content": "{avatar_emoji}" }
            }
          ]
        }
      ]
    },
    { "tag": "hr" },
    {
      "tag": "div",
      "fields": [
        { "is_short": true, "text": { "tag": "lark_md", "content": "**{field1_label}**\n{field1_value}" } },
        { "is_short": true, "text": { "tag": "lark_md", "content": "**{field2_label}**\n{field2_value}" } },
        { "is_short": true, "text": { "tag": "lark_md", "content": "**{field3_label}**\n{field3_value}" } },
        { "is_short": true, "text": { "tag": "lark_md", "content": "**{field4_label}**\n{field4_value}" } }
      ]
    },
    { "tag": "hr" },
    {
      "tag": "div",
      "text": { "tag": "lark_md", "content": "**{section_title}**\n{section_content}" }
    }
  ]
}
