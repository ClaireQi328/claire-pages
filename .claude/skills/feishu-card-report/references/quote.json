{
  "config": { "wide_screen_mode": true },
  "header": {
    "title": { "tag": "plain_text", "content": "💬 {引用标题}" },
    "template": "yellow"
  },
  "elements": [
    {
      "tag": "div",
      "text": { "tag": "lark_md", "content": "> {quote_text}" }
    },
    { "tag": "hr" },
    {
      "tag": "note",
      "elements": [
        { "tag": "plain_text", "content": "— {quote_author}, {quote_source}" }
      ]
    }
  ]
}
