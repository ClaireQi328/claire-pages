{
  "config": { "wide_screen_mode": true },
  "header": {
    "title": { "tag": "plain_text", "content": "🚀 {进度标题}" },
    "template": "green"
  },
  "elements": [
    {
      "tag": "div",
      "text": { "tag": "lark_md", "content": "**总体进度** {progress_bar} **{progress_percent}%**" }
    },
    { "tag": "hr" },
    {
      "tag": "div",
      "text": {
        "tag": "lark_md",
        "content": "✅ **阶段1**：{stage1_name} — {stage1_status}\n🔵 **阶段2**：{stage2_name} — {stage2_status}\n⚪ **阶段3**：{stage3_name} — {stage3_status}"
      }
    },
    { "tag": "hr" },
    {
      "tag": "note",
      "elements": [
        { "tag": "plain_text", "content": "📅 更新时间：{update_time}" }
      ]
    }
  ]
}
