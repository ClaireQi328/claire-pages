          "elements": [
            {
              "tag": "div",
              "text": { "tag": "lark_md", "content": "**{col2_title}**\n{col2_value}\n{col2_trend}" }
            }
          ]
        },
        {
          "tag": "column",
          "width": "weighted",
          "weight": 1,
          "vertical_align": "top",
          "elements": [
            {
              "tag": "div",
              "text": { "tag": "lark_md", "content": "**{col3_title}**\n{col3_value}\n{col3_trend}" }
