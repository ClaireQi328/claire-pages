{
  "config": { "wide_screen_mode": true },
  "header": {
    "title": { "tag": "plain_text", "content": "⚠️ {风险报告标题}" },
    "template": "{risk_color}"
  },
  "elements": [
    {
      "tag": "column_set",
      "flex_mode": "none",
      "background_style": "default",
      "columns": [
        {
          "tag": "column",
          "width": "weighted",
          "weight": 1,
          "vertical_align": "top",
          "elements": [
            {
              "tag": "div",
              "text": { "tag": "lark_md", "content": "🔴 **高风险**\n{high_risk_count} 项" }
            }
          ]
        },
        {
          "tag": "column",
          "width": "weighted",
          "weight": 1,
          "vertical_align": "top",
          "elements": [
            {
              "tag": "div",
              "text": { "tag": "lark_md", "content": "🟡 **中风险**\n{medium_risk_count} 项" }
            }
          ]
        },
        {
          "tag": "column",
          "width": "weighted",
          "weight": 1,
          "vertical_align": "top",
          "elements": [
            {
              "tag": "div",
              "text": { "tag": "lark_md", "content": "🟢 **低风险**\n{low_risk_count} 项" }
            }
          ]
        }
      ]
    },
    { "tag": "hr" },
    {
      "tag": "div",
      "text": { "tag": "lark_md", "content": "**风险详情**\n{risk_details}" }
    },
    { "tag": "hr" },
    {
      "tag": "action",
      "actions": [
        {
          "tag": "button",
          "text": { "tag": "plain_text", "content": "查看详情" },
          "type": "primary",
          "url": "{detail_url}"
        },
        {
          "tag": "button",
          "text": { "tag": "plain_text", "content": "导出报告" },
          "type": "default"
        }
      ]
    }
  ]
}
