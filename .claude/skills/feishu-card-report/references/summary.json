{
  "config": { "wide_screen_mode": true },
  "header": {
    "title": { "tag": "plain_text", "content": "📊 {报告标题}" },
    "template": "{color}"
  },
  "elements": [
    {
      "tag": "div",
      "fields": [
        { "is_short": true, "text": { "tag": "lark_md", "content": "**指标1**\n{value1}" } },
        { "is_short": true, "text": { "tag": "lark_md", "content": "**指标2**\n{value2}" } },
        { "is_short": true, "text": { "tag": "lark_md", "content": "**指标3**\n{value3}" } },
        { "is_short": true, "text": { "tag": "lark_md", "content": "**指标4**\n{value4}" } }
      ]
    },
    { "tag": "hr" },
    {
      "tag": "div",
      "text": { "tag": "lark_md", "content": "**核心结论**\n{conclusion}" }
    },
    { "tag": "hr" },
    {
      "tag": "note",
      "elements": [
        { "tag": "plain_text", "content": "📅 {date} | 🔄 {update_freq}" }
      ]
    }
  ]
}
